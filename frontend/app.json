{
  "expo": {
    "name": "alerte-ecole",
    "slug": "alerte-ecole",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alerteecole",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.meresse.alerteecole",
      "supportsTablet": true
    },
    "android": {
      "package": "com.meresse.alerteecole",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#e63946",
          "sounds": [
            "./assets/sounds/incendie.wav",
            "./assets/sounds/confinement.wav",
            "./assets/sounds/medical.wav",
            "./assets/sounds/exercise.wav"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiHost": "192.168.1.221",
      "apiPort": 8800,
      "router": {},
      "eas": {
        "projectId": "dd4ec6b5-1460-4133-bbfa-eac107b9ed19"
      }
    },
    "owner": "damien27"
  }
}
